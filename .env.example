# ═══════════════════════════════════════════════════════
# FurnAI — Complete Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ── AI APIs ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── 3D Model Generation (Meshy.ai) ──────────────────
# Get your key at: https://app.meshy.ai/settings/api-keys
# Test mode key: msy_dummy_api_key_for_test_mode_12345678
MESHY_API_KEY=your_meshy_api_key_here

# ── Supabase (Database, Auth, Storage) ───────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Stripe Payments ──────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Email (Resend) ───────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=FurnAI <orders@furnai.com>

# ── WhatsApp Business (Factory Notifications) ────────
# Get these from: https://developers.facebook.com/apps
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_FACTORY_NUMBER=your_factory_phone_number_here

# ── Cloudinary (Image/Texture Management) ────────────
# Get these from: https://console.cloudinary.com/settings
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ── GitHub ───────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# ── Brave Search (for MCP) ───────────────────────────
# Get your key at: https://brave.com/search/api/
BRAVE_API_KEY=BSA_your_brave_api_key_here

# ── App Configuration ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FurnAI
